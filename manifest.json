{
  "manifest_version": 3,
  "name": "PageVoice",
  "version": "1.1.0",
  "description": "Read articles aloud using ElevenLabs or local TTS - turn any webpage into audio",
  "permissions": ["storage", "activeTab", "scripting", "offscreen"],
  "host_permissions": ["https://api.elevenlabs.io/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
