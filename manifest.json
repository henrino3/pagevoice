{
  "manifest_version": 3,
  "name": "PageVoice",
  "version": "2.0.0",
  "description": "Read articles aloud — Edge TTS, OpenAI, ElevenLabs, or local TTS",
  "permissions": ["storage", "activeTab", "scripting", "offscreen", "tabs"],
  "host_permissions": [
    "https://api.elevenlabs.io/*",
    "https://api.openai.com/*",
    "https://api.streamelements.com/*",
    "https://speech.platform.bing.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content-player.css"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
